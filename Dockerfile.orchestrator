FROM python:3.11-slim

WORKDIR /app
ENV PYTHONPATH=/app

RUN pip install --no-cache-dir \
    "fastapi>=0.110" \
    "uvicorn[standard]>=0.29" \
    "httpx>=0.27" \
    "python-json-logger>=2.0" \
    "pydantic-settings>=2.0" \
    "sqlalchemy[asyncio]>=2.0" \
    "asyncpg>=0.29" \
    "sse-starlette>=2.0" \
    "openpyxl>=3.1" \
    "rapidfuzz>=3.0" \
    "passlib>=1.7.4" \
    "bcrypt==4.0.1" \
    "pyjwt>=2.8" \
    "langgraph>=0.1" \
    "langchain-core>=0.2" \
    "langchain-openai" \
    "langchain-anthropic" \
    "langchain-ollama"

COPY shared ./shared
COPY a2a ./a2a
COPY orchestrator ./orchestrator

EXPOSE 8000
CMD ["uvicorn", "orchestrator.main:app", "--host", "0.0.0.0", "--port", "8000"]
