# ============================================================================
# Orbo — environment configuration
#
# These are LOCAL / dev defaults. Copy to .env and fill the blanks, then
# `docker compose up`. Every value here is a variable — nothing is hardcoded
# per environment. In PROD (Azure Container Apps) the CI/CD pipeline injects
# the same variables from the GitHub `production` Environment (see
# DEPLOY-AZURE.md). Vars whose value differs in prod are annotated `# prod: …`.
# ============================================================================

# ── Postgres ────────────────────────────────────────────────────────────────
# Local dev: your local/compose Postgres.
# prod: NeonDB, e.g.
#   postgresql+asyncpg://<user>:<pw>@<ep>-pooler.<region>.aws.neon.tech/orbo?ssl=require
DATABASE_URL=postgresql+asyncpg://standup:standup@postgres:5432/standup

# ── Recall.ai ─────────────────────────────────────────────────────────────────
RECALL_API_KEY=
RECALL_WEBHOOK_SECRET=
RECALL_REGION=us-west-2
# Local dev: your ngrok URL. prod: the frontend's public FQDN
#   (Recall posts to  https://<frontend-fqdn>/webhooks/recall ).
RECALL_WEBHOOK_BASE_URL=https://<your-ngrok-or-public-url>

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ── Microsoft Graph (leave blank to skip email delivery) ─────────────────────
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_SENDER_EMAIL=

# ── App ───────────────────────────────────────────────────────────────────────
GATEWAY_API_KEY=changeme
INTERNAL_SERVICE_TOKEN=changeme-internal
LOG_LEVEL=INFO
ENV=local

# ── Multi-user auth (JWT) ────────────────────────────────────────────────────
# MUST be overridden with a long random value in any real deployment.
JWT_SECRET=change-this-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=10080

# ── Frontend → orchestrator proxy (nginx) ─────────────────────────────────────
# The frontend container serves the SPA and proxies /api and /webhooks here.
# Local dev: the compose orchestrator. prod: the orchestrator's INTERNAL
# Container Apps FQDN, e.g. https://orchestrator.internal.<env>.<region>.azurecontainerapps.io
ORCHESTRATOR_URL=http://orchestrator:8000

# ── LLM orchestrator (A2A client) ───────────────────────────────────────────
# azure_openai (default) | anthropic | ollama
LLM_PROVIDER=azure_openai
ORCHESTRATOR_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-6
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── SLM (agent skills, provider-configurable per skill) ──────────────────────
# azure_openai (default) | groq | ollama
SLM_PROVIDER=azure_openai
GROQ_API_KEY=
# GPT-4o for summarize — deliberately not swapped for a smaller model.
SUMMARIZE_MODEL=gpt-4o
# Swap to a smaller/cheaper model later — env-only change, no code changes.
DELIVER_MODEL=gpt-4o

# ── Agent role ───────────────────────────────────────────────────────────────
# Selects which card + skill set an agent process serves. Set per-container
# (standup-agent -> standup, project-agent -> project); both run from one image.
AGENT_ROLE=standup

# ── A2A (agents the orchestrator talks to) ──────────────────────────────────
# prod: A2A_SCHEME=https, *_HOST=<internal FQDN>, *_PORT=443
A2A_SCHEME=http
STANDUP_AGENT_ENABLED=true
STANDUP_AGENT_HOST=standup-agent
STANDUP_AGENT_PORT=8020
PROJECT_AGENT_ENABLED=true
PROJECT_AGENT_HOST=project-agent
PROJECT_AGENT_PORT=8021

# ── MCP (standup-tools server) ──────────────────────────────────────────────
# prod (callers): MCP_SCHEME=https, MCP_HOST=<internal FQDN>, MCP_PORT=443.
# The mcp container itself keeps MCP_PORT=8010 (its own listen port).
MCP_SCHEME=http
MCP_HOST=standup-mcp
MCP_PORT=8010
