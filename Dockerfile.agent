FROM python:3.11-slim

WORKDIR /app
ENV PYTHONPATH=/app

RUN pip install --no-cache-dir \
    "fastapi>=0.110" \
    "uvicorn[standard]>=0.29" \
    "httpx>=0.27" \
    "python-json-logger>=2.0" \
    "pydantic-settings>=2.0" \
    "openai>=1.0" \
    "markdown>=3.6" \
    "mcp==1.26.0" \
    "langchain-mcp-adapters==0.2.1" \
    "langgraph>=0.1" \
    "langchain-core>=0.2" \
    "langchain-openai" \
    "langchain-anthropic" \
    "langchain-ollama"
# Note: SLM_PROVIDER=groq requires `langchain-groq`, not installed by default —
# add it here if you enable that provider.

COPY shared ./shared
COPY a2a ./a2a
COPY agent ./agent

EXPOSE 8020
CMD ["uvicorn", "agent.server:app", "--host", "0.0.0.0", "--port", "8020"]
